{
  "dataset": {
    "data_path": "../data/synthetic_training_data.csv",
    "components": ["cement", "sand", "gravel", "water"],
    "properties": ["strength_28"]
  },
  "discriminator_config": {
    "limit_generations": 5,
    "top_k": 2,
    "seed": 42
  },
  "random_seed": 42,
  "generator_mc_samples": 24,
  "num_epochs": 50,
  "batch_size": 8,
  "discriminator_learning_rate": 0.001,
  "generator_learning_rate": 0.0001,
  "adversarial_weight": 1.0,
  "reconstruction_weight": 0.5,
  "constraint_weight": 0.1,
  "warmup_epochs": 5,
  "discriminator_hidden_layers": [64, 32],
  "use_spectral_norm": false,
  "discriminator_steps_per_epoch": 1,
  "generator_steps_per_epoch": 1,
  "gradient_penalty_weight": 10.0,
  "use_focal_loss": false,
  "focal_loss_gamma": 2.0,
  "label_smoothing": 0.0
}
